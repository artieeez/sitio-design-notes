{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sitio.local/schemas/wix-payment-event.ui.schema.json",
  "title": "WixPaymentEventUI",
  "description": "UI-facing payment event payload (mock and future API alignment). Field keys match design sample wix-payment-event-entity.json.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "dateCreated",
    "buyerInfoId",
    "buyerIndoFirstname",
    "buyerIndoLastname",
    "buyerIndoPhone",
    "buyerIndoEmail",
    "buyerIndoContactId",
    "orderId",
    "orderTotal",
    "billingInfoPaymentMethod",
    "billingInfoCountry",
    "billingInfoSubdivision",
    "billingInfoCity",
    "billingInfoZipCode",
    "billingInfoPhone",
    "billingInfoEmail",
    "billingInfoVatIdNumber",
    "billingInfoVatIdType",
    "billingInfoStreetNumber",
    "billingInfoStreetName",
    "lineItemsName",
    "lineItemsProductId"
  ],
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "dateCreated": { "type": "string", "format": "date-time" },
    "buyerInfoId": { "type": "string", "format": "uuid" },
    "buyerIndoFirstname": { "type": "string" },
    "buyerIndoLastname": { "type": "string" },
    "buyerIndoPhone": { "type": "string" },
    "buyerIndoEmail": { "type": "string" },
    "buyerIndoContactId": { "type": "string", "format": "uuid" },
    "orderId": { "type": "string", "format": "uuid" },
    "orderTotal": { "type": "string" },
    "billingInfoPaymentMethod": { "type": "string" },
    "billingInfoCountry": { "type": "string" },
    "billingInfoSubdivision": { "type": "string" },
    "billingInfoCity": { "type": "string" },
    "billingInfoZipCode": { "type": "string" },
    "billingInfoPhone": { "type": "string" },
    "billingInfoEmail": { "type": "string" },
    "billingInfoVatIdNumber": { "type": "string" },
    "billingInfoVatIdType": { "type": "string" },
    "billingInfoStreetNumber": { "type": "string" },
    "billingInfoStreetName": { "type": "string" },
    "lineItemsName": { "type": "string" },
    "lineItemsProductId": { "type": "string" },
    "lineItemsOptions": { "type": "string" },
    "lineItemsCustomTextFields": { "type": "string" }
  }
}
